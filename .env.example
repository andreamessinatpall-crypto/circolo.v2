# Copia questo file in ".env.local" e inserisci i valori del tuo progetto Supabase.
# Li trovi in: Supabase > Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=la-tua-chiave-anon

# Fase 1 (push): chiave pubblica VAPID (genera la coppia con `npx web-push
# generate-vapid-keys`). La privata NON va qui: è un secret della Edge
# Function `invia-push` (supabase secrets set VAPID_PRIVATE_KEY=...).
VITE_VAPID_PUBLIC_KEY=la-tua-chiave-pubblica-vapid
